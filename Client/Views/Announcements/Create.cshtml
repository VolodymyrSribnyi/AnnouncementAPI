@using Client.Models.Enums
@model Client.Models.AnnouncementDTO

@{
    ViewData["Title"] = "Створити оголошення";
}

<div class="form-container">
    <h1>Створити оголошення</h1>

    <form asp-action="Create" method="post" class="form">

        <div class="form-group">
            <label>Назва</label>
            <input asp-for="Title" class="form-control" />
        </div>

        <div class="form-group">
            <label>Опис</label>
            <textarea asp-for="Description" class="form-control"></textarea>
        </div>

        <div class="form-group">
            <label>Статус</label>
            <select asp-for="Status" class="form-control"
                    asp-items="Html.GetEnumSelectList<Status>()">
            </select>
        </div>

        <div class="form-group">
            <label>Категорія</label>
            <select asp-for="Category" class="form-control"
                    asp-items="Html.GetEnumSelectList<Category>()">
            </select>
        </div>

        <div class="form-group">
            <label>Підкатегорія</label>
            <select asp-for="SubCategory" class="form-control"
                    asp-items="Html.GetEnumSelectList<SubCategory>()">
            </select>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Створити</button>
            <a asp-action="Index" class="btn btn-outline">Скасувати</a>
        </div>
    </form>
</div>